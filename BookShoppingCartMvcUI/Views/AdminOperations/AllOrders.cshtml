@model IEnumerable<Order>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_AdminLayout";
}
<div style="width:100%" class="mt-2">
    <h4>Orders</h4>
    @if (Model != null && Model.Count() > 0)
    {
        <table class="table talbe-striped">
            <tr>
                <th>OrderDate</th>
                <th>Name</th>
                <th>Email</th>
                <th>MobileNo</th>
                <th>Address</th>
                <th>PaymentStatus</th>
                <th>OrderStatus</th>
                <th>Actions</th>
            </tr>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.CreateDate.ToString("MM-dd-yyyy")</td>
                    <td>@order.Name</td>
                    <td>@order.Email</td>
                    <td>@order.MobileNumber</td>
                    <td>@order.Address</td>
                    <td>@order.PaymentMethod | @(order.IsPaid? "Paid":"Not Paid")</td>
                    <td>@order.OrderStatus.StatusName</td>
                    <td>
                        <button type="button" class="btn btn-primary my-1" data-bs-toggle="modal"
                                data-bs-target="#model-@order.Id">Order-Detial</button>
                        <a asp-action="UpdateOrderStatus" asp-route-orderId="@order.Id" class="btn btn-info my-1">Change Order
                            Status</a>
                            <a asp-action="TogglePaymentStatus" asp-route-orderId="@order.Id" class="btn btn-info my-1">Toggle Payment
                                Status</a>
                                @*appending modal here*@

                                @*await @Html.PartialAsync("/Views/AdminOperations/_OrderDetialModal.cshtml",new OrderDetialModalDTO {Divid=order.Id.ToString(),OrderDetail=order.OrderDetail })*@ 

                                <partial name="/Views/AdminOperations/_OrderDetialModal.cshtml"
                                         model="new OrderDetialModalDTO{Divid=order.Id.ToString(),OrderDetail=order.OrderDetail }">

                                </td>
                            </tr>
                        }
                    </table>
                }
    else
                {
                    <h5>No orders</h5>
                }
            </div>