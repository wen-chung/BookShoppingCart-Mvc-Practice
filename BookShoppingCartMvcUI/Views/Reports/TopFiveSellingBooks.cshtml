@model TopNSoldBooksVm

@{
    Layout = "_AdminLayout";
}

<h3>Top Selling Books</h3>

@if (Model != null) { 
    <div>
        <form asp-action="TopFiveSellingBooks" class="my-2 d-flex" style="gap:5px" method="get">
            <input type="date" class="form-control" style="width:200px" name="sDate">
              <input type="date" class="form-control" style="width:200px" name="eDate">

              <button class="btn btn-primary">Filter</button>
              <a class="btn btn-primary" href="/Reports/TopFiveSellingBooks">Clear</a>
        </form>

        <h4>Showing result from @Model.StartDate.ToString("MMM-dd-yyyy") to @Model.EndDate.ToString("MMM-dd-yyyy")</h4>

        @if (Model.TopNSoldBooks.Count() == 0)
        {
            <div class="my-3" style="font-size: 16px;font-weight:bold">
                No records found
            </div>
        }
        else { 
            <table style="width: 50%;" class="table table-striped">
                <thead>
                    <th>Book</th>
                    <th>Sold Units</th>
                </thead>
                <tbody>
                    @foreach (var item in Model.TopNSoldBooks) { 
                        <tr>
                            <td>@item.BookName by @item.AuthorName</td>
                            <td>@item.TotalUnitSold</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

    </div>
}
else{
    <h4>Something went wrong</h4>
}